<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="dynamic_dashboard.DashboardView">
        <div class="o_dashboard_view">
            <div class="o_control_panel d-flex">
                <div class="o_cp_left">
                    <h2 class="o_cp_title">Dashboard</h2>
                </div>
                <div class="o_cp_right">
                    <button class="btn btn-primary me-2" t-on-click="openDashboardForm">
                        <i class="fa fa-plus"/> Manage Dashboards
                    </button>
                    <button class="btn btn-secondary" t-on-click="refreshDashboard">
                        <i class="fa fa-refresh"/> Refresh
                    </button>
                </div>
            </div>

            <div class="o_content">
                <!-- Dashboard Selector -->
                <div class="o_dashboard_selector p-3 bg-light">
                    <label class="me-2 fw-bold">Select Dashboard:</label>
                    <select class="form-select d-inline-block w-auto"
                            t-on-change="selectDashboard">
                        <t t-foreach="state.dashboards" t-as="dashboard" t-key="dashboard.id">
                            <option t-att-value="dashboard.id"
                                    t-att-selected="dashboard.id === state.selectedDashboard">
                                <t t-esc="dashboard.name"/>
                            </option>
                        </t>
                    </select>
                </div>

                <!-- Loading -->
                <div t-if="state.loading" class="text-center p-5">
                    <i class="fa fa-spinner fa-spin fa-3x text-muted"/>
                    <p class="text-muted mt-3">Loading...</p>
                </div>

                <!-- No Dashboard -->
                <div t-elif="state.dashboards.length === 0" class="text-center p-5">
                    <i class="fa fa-bar-chart fa-3x text-muted mb-3"/>
                    <h4 class="text-muted">No Dashboards Found</h4>
                    <p class="text-muted">Create your first dashboard to get started</p>
                    <button class="btn btn-primary" t-on-click="openDashboardForm">
                        <i class="fa fa-plus"/> Create Dashboard
                    </button>
                </div>

                <!-- Charts Grid -->
                <div t-elif="state.charts.length > 0" class="o_dashboard_charts p-3">
                    <div class="row">
                        <t t-foreach="state.charts" t-as="chart" t-key="chart.id">
                            <div class="col-md-6 col-lg-6 mb-4">
                                <ChartComponent
                                    chartId="chart.id"
                                    chartName="chart.name"
                                    chartType="chart.chart_type"
                                    colorScheme="chart.color_scheme"
                                    onEdit.bind="editChart"/>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- No Charts -->
                <div t-else="" class="text-center p-5">
                    <i class="fa fa-line-chart fa-3x text-muted mb-3"/>
                    <h4 class="text-muted">No Charts in this Dashboard</h4>
                    <p class="text-muted">Add charts to visualize your data</p>
                </div>
            </div>
        </div>
    </t>
</templates>